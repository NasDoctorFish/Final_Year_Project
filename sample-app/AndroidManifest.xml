<?xml version="1.0" encoding="utf-8"?>
<!--
  BioAuthGuard VulnDemo — a DELIBERATELY INSECURE test app.

  Install it on a device you own and point `bioauthguard assess` at it to see the
  runtime detectors fire. Do not ship anything resembling this.

  Planted weaknesses:
    * SecretActivity is exported with no permission → the IPC oracle can launch the
      "post-auth" screen directly, bypassing the biometric gate (OWASP M3).
    * TokenCheckProvider is an exported, unguarded auth-state oracle: it answers a
      valid identifier differently from an invalid one → response-oracle side-channel
      detector (M3/M1).
    * Both screens log a session token to logcat → logcat-leak observer (M9/M6).
    * allowBackup=true → data extractable via adb backup (M9).
    * debuggable=true and a boolean-only biometric check → static-analysis findings.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.bioauthguard.vulndemo">

    <uses-permission android:name="android.permission.USE_BIOMETRIC"/>

    <application
        android:allowBackup="true"
        android:debuggable="true"
        android:label="@string/app_name"
        android:icon="@android:drawable/sym_def_app_icon">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- VULN: the "secret" post-auth screen is exported with no permission
             guard, so it can be started directly without authenticating. -->
        <activity
            android:name=".SecretActivity"
            android:exported="true"/>

        <!-- VULN: an exported, unguarded provider that leaks auth state — it answers
             a valid identifier differently from an invalid one, an enumeration oracle
             an unauthenticated caller can query over adb (the response-oracle side
             channel). A secure provider would need a permission and a constant response. -->
        <provider
            android:name=".TokenCheckProvider"
            android:authorities="com.bioauthguard.vulndemo.tokens"
            android:exported="true"/>

    </application>
</manifest>
